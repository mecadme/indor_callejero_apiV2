<?xml version="1.0" encoding="UTF-8"?>
<!--
  Cada exclusión de acá es una decisión, no un silenciador genérico.
  Antes de agregar una entrada nueva, preguntate si es genuinamente el
  mismo caso que ya está documentado o si es un bug real disfrazado de
  falso positivo. Y si una entrada puntual se repite dos o tres veces con
  la misma explicación, es momento de generalizarla por convención de
  nombre en vez de seguir listando clases (pasó con Controller/Service en
  la Etapa 6, después de la Etapa 5).
-->
<FindBugsFilter>

    <!--
      AuthenticationManager.authenticate() está documentado para devolver
      siempre un Authentication no-nulo o lanzar AuthenticationException,
      nunca null. SpotBugs no puede leer ese contrato desde la interfaz,
      solo ve un tipo de retorno sin @NonNull.
    -->
    <Match>
        <Class name="com.indorcallejero.api.auth.AuthService"/>
        <Method name="login"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!--
      UserPrincipal envuelve un UserEntity a propósito: es una vista viva
      sobre la entidad gestionada por Hibernate, no un value object que
      deba copiarse defensivamente (copiarlo rompería el propósito de la
      clase). SE_BAD_FIELD: Serializable llega heredado de UserDetails,
      pensado para sesiones HTTP con estado; esta app es 100% stateless
      (JWT), este principal nunca se serializa de verdad.
    -->
    <Match>
        <Class name="com.indorcallejero.api.auth.UserPrincipal"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP2"/>
            <Bug pattern="SE_BAD_FIELD"/>
        </Or>
    </Match>

    <!--
      Cualquier *Controller o *Service del proyecto: son beans de Spring,
      sus constructores reciben otros beans (repositories, otros
      services, filtros): esa es la única forma de hacer inyección de
      dependencias acá, no una referencia externa mutable en el sentido
      que le preocupa a esta regla. Generalizado por convención de
      nombre porque aparece con cada dominio nuevo (Etapa 1 ya tenía
      UserController/UserService, la Etapa 6 sumó Team* y Player*, van a
      seguir sumándose).
    -->
    <Match>
        <Class name="~com\.indorcallejero\.api\..*(Controller|Service)"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
      Un puñado fijo de infraestructura de seguridad/errores con el mismo
      patrón de inyección por constructor, pero fuera de la convención
      Controller/Service.
    -->
    <Match>
        <Class name="com.indorcallejero.api.config.SecurityConfig"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="com.indorcallejero.api.error.JsonErrorWriter"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="com.indorcallejero.api.error.RestAccessDeniedHandler"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    <Match>
        <Class name="com.indorcallejero.api.error.RestAuthenticationEntryPoint"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
      Cualquier *Entity: las relaciones @ManyToOne/@OneToOne (ej.
      PlayerEntity.team) devuelven y reciben la entidad relacionada
      directamente: así funciona JPA. No hay copia defensiva razonable:
      copiar una entidad gestionada por Hibernate la desconecta del
      contexto de persistencia y rompe el dirty-checking que hace que
      guardar cambios funcione. Va a repetirse en cada relación
      entidad-entidad nueva (Match-Team, Match-Player, etc.).
    -->
    <Match>
        <Class name="~com\.indorcallejero\.api\..*Entity"/>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <!--
      CT_CONSTRUCTOR_THROW en *Entity: no lo arreglamos con "final" como en
      JwtService/SecurityConfig (Etapa 5) a propósito. Esos son beans
      planos que Spring nunca subclasea; una entidad JPA sí puede
      necesitar que Hibernate genere un proxy de ella para carga LAZY el
      día que otra entidad la referencie (ej. MatchEntity.homeTeam ya lo
      hace con TeamEntity; el día que una LineUp o un evento de partido
      referencie MatchEntity de forma LAZY, "final" rompería esa relación
      en tiempo de ejecución). Constructores de entidad que validan
      invariantes (MatchEntity: "un equipo no juega contra sí mismo") van
      a seguir lanzando excepción a propósito: es la excepción correcta,
      no un bug.
    -->
    <Match>
        <Class name="~com\.indorcallejero\.api\..*Entity"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

</FindBugsFilter>
